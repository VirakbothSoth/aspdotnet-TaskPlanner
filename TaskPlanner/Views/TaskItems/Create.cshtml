@model TaskPlanner.Models.TaskItem

@{
    ViewData["Title"] = "New Task";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted" style="font-size:13px">&larr; Back to tasks</a>
    <h4 class="mb-0" style="font-weight:500">New Task</h4>
</div>

<div class="rounded-3 p-4" style="border:0.5px solid #dee2e6; background:#fff; max-width:520px">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="mb-3">
            <label asp-for="Title" class="mb-1" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger" style="font-size:12px"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="mb-1" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d"></label>
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="text-danger" style="font-size:12px"></span>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-sm-6">
                <label asp-for="Priority" class="mb-1" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d"></label>
                <select asp-for="Priority" asp-items="Html.GetEnumSelectList<TaskPlanner.Models.Priority>()" class="form-select"></select>
                <span asp-validation-for="Priority" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="EndDate" class="mb-1" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d"></label>
                <input asp-for="EndDate" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger" style="font-size:12px"></span>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-sm-6">
                <label asp-for="Hashtag" class="mb-1" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d"></label>
                <input asp-for="Hashtag" class="form-control" />
                <span asp-validation-for="Hashtag" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="Comment" class="mb-1" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d"></label>
                <input asp-for="Comment" class="form-control" />
                <span asp-validation-for="Comment" class="text-danger" style="font-size:12px"></span>
            </div>
        </div>

        <div class="mb-3">
            <label class="mb-1 d-block" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d">Attachment</label>
            <input type="file" name="attachment" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="ParentTaskId" class="mb-1" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d"></label>
            <select asp-for="ParentTaskId" class="form-select" asp-items="ViewBag.ParentTaskId">
                <option value="">-- None (Top Level Task) --</option>
            </select>
        </div>

        <div class="d-flex gap-2 mt-4">
            <input type="submit" value="Create Task" class="btn btn-primary rounded-pill px-4" />
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
