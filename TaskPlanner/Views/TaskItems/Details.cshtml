@model TaskPlanner.Models.TaskItem

@{
    ViewData["Title"] = "Task Details";

    var accentColor = Model.IsCompleted ? "#198754" :
                       Model.Priority == TaskPlanner.Models.Priority.High ? "#dc3545" :
                       Model.Priority == TaskPlanner.Models.Priority.Medium ? "#ffc107" : "#adb5bd";

    var badgeClass = Model.IsCompleted ? "bg-success-subtle text-success-emphasis" :
                      Model.Priority == TaskPlanner.Models.Priority.High ? "bg-danger-subtle text-danger-emphasis" :
                      Model.Priority == TaskPlanner.Models.Priority.Medium ? "bg-warning-subtle text-warning-emphasis" :
                      "bg-secondary-subtle text-secondary-emphasis";

    var badgeLabel = Model.IsCompleted ? "Done" : Model.Priority.ToString();

    var imageExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp", ".svg" };
    var attachmentExt = string.IsNullOrEmpty(Model.AttachmentPath) ? "" : System.IO.Path.GetExtension(Model.AttachmentPath).ToLowerInvariant();
    var isImageAttachment = imageExtensions.Contains(attachmentExt);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted" style="font-size:13px">&larr; Back to tasks</a>
    <div class="d-flex align-items-center gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm rounded-pill px-3">Delete</a>
    </div>
</div>

<div class="rounded-3 overflow-hidden" style="border:0.5px solid #dee2e6; background:#fff; display:flex">
    <div style="width:5px; background:@accentColor; flex-shrink:0"></div>
    <div class="p-4 flex-grow-1">
        <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
            <h3 class="mb-0 @(Model.IsCompleted ? "text-decoration-line-through text-muted" : "")" style="font-weight:500">@Model.Title</h3>
            <span class="badge rounded-pill @badgeClass flex-shrink-0" style="font-size:12px">@badgeLabel</span>
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted mb-4" style="font-size:14px">@Model.Description</p>
        }

        <div class="row g-4 mb-4">
            <div class="col-sm-6">
                <div class="mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d">Due date</div>
                <div style="font-size:14px">
                    @if (Model.EndDate.HasValue)
                    {
                        var overdue = !Model.IsCompleted && Model.EndDate < DateTime.Now;
                        <span class="@(overdue ? "text-danger fw-semibold" : "")">
                            @Model.EndDate.Value.ToString("MMM d, yyyy")
                            @if (overdue) { <span>(overdue)</span> }
                        </span>
                    }
                    else
                    {
                        <span class="text-muted">No due date</span>
                    }
                </div>
            </div>
            <div class="col-sm-6">
                <div class="mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d">Hashtag</div>
                <div style="font-size:14px">
                    @if (!string.IsNullOrEmpty(Model.Hashtag))
                    {
                        <span style="color:#0d6efd;font-family:monospace">@Model.Hashtag</span>
                    }
                    else
                    {
                        <span class="text-muted">None</span>
                    }
                </div>
            </div>
            <div class="col-sm-6">
                <div class="mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d">Parent task</div>
                <div style="font-size:14px">
                    @if (Model.ParentTask != null)
                    {
                        <a asp-action="Details" asp-route-id="@Model.ParentTask.Id" class="text-decoration-none">@Model.ParentTask.Title</a>
                    }
                    else
                    {
                        <span class="text-muted">Top-level task</span>
                    }
                </div>
            </div>
            <div class="col-sm-6">
                <div class="mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d">Comment</div>
                <div style="font-size:14px">
                    @if (!string.IsNullOrEmpty(Model.Comment))
                    {
                        @Model.Comment
                    }
                    else
                    {
                        <span class="text-muted">None</span>
                    }
                </div>
            </div>
        </div>

        <div>
            <div class="mb-2" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d">Attachment</div>
            @if (!string.IsNullOrEmpty(Model.AttachmentPath))
            {
                <a href="@Model.AttachmentPath" target="_blank" class="d-inline-block text-decoration-none" title="Open attachment in a new tab">
                    @if (isImageAttachment)
                    {
                        <img src="@Model.AttachmentPath" alt="Attachment thumbnail" class="rounded-3"
                             style="max-width:240px;max-height:180px;object-fit:cover;border:0.5px solid #dee2e6" />
                    }
                    else
                    {
                        <span class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-3"
                              style="border:0.5px solid #dee2e6;background:var(--bs-light);font-size:13px;color:#0d6efd">
                            📎 @System.IO.Path.GetFileName(Model.AttachmentPath)
                        </span>
                    }
                </a>
            }
            else
            {
                <span class="text-muted" style="font-size:13px">No attachment</span>
            }
        </div>

        @if (Model.SubTasks.Any())
        {
            <div class="mt-4 pt-3" style="border-top:0.5px solid #dee2e6">
                <div class="mb-2" style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#6c757d">
                    Subtasks — @Model.SubTasks.Count(s => s.IsCompleted) / @Model.SubTasks.Count done
                </div>
                @foreach (var sub in Model.SubTasks)
                {
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span style="width:6px;height:6px;border-radius:50%;flex-shrink:0;@(sub.IsCompleted ? "background:#198754" : "border:1.5px solid #adb5bd")"></span>
                        <a asp-action="Details" asp-route-id="@sub.Id" class="text-decoration-none @(sub.IsCompleted ? "text-muted text-decoration-line-through" : "")" style="font-size:13px">
                            @sub.Title
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</div>
